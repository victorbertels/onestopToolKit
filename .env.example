# Copy to `.env` and fill in. Never commit `.env`.

CLIENT_ID=
CLIENT_SECRET=

# Deliverect account Mongo `_id` (Streamlit default + CLI export/import).
ACCOUNT_ID=

# Just Eat channel link template (retail channel setup).
JUST_EAT_API_KEY=

# Optional: Zapier webhook for page visit tracking (Streamlit).
ZAPIER_WEBHOOK_URL=

# Password required to access the Streamlit app.
APP_PASSWORD=
