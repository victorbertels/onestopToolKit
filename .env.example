# Copy to `.env` and fill in. Never commit `.env`.

CLIENT_ID=
CLIENT_SECRET=

# Deliverect account Mongo `_id` — must be the OneStop account for this toolkit.
ACCOUNT_ID=6963884edc8e7760066fa547

# Optional override for Quest prep template location (defaults to a known-good OneStop site).
QUEST_PREP_TEMPLATE_LOCATION_ID=

# Just Eat channel link template (retail channel setup).
JUST_EAT_API_KEY=

# Optional: Zapier webhook for page visit tracking (Streamlit).
ZAPIER_WEBHOOK_URL=

# Password required to access the Streamlit app.
APP_PASSWORD=
